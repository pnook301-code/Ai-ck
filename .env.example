# ─── Nexus Core Environment Variables ───
# Copy this file to .env and fill in your values

# --- API Providers ---
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_HOST=http://localhost:11434

# --- Security ---
JWT_SECRET=
ENCRYPTION_KEY=

# --- Integrations ---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
TELEGRAM_BOT_TOKEN=

# --- Database ---
DATABASE_PATH=~/.nexus-core/data
LOG_LEVEL=INFO

# --- Deployment ---
NODE_ENV=production
PORT=8080
