# ─── CK-NEXUS AIOS Environment Variables ───
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- AI Provider API Keys (at least one required) ---
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_HOST=http://localhost:11434

# --- Security (auto-generated if empty) ---
JWT_SECRET=
ENCRYPTION_KEY=

# --- Cloud Provider API Keys (optional) ---
HETZNER_API_TOKEN=
DIGITALOCEAN_API_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=

# --- Shadow Bridge ---
CK_SHADOW_HOME=/opt/ck-nexus-aios

# --- Deployment ---
NODE_ENV=production
PORT=8080
LOG_LEVEL=INFO
DATABASE_PATH=~/.nexus-core/data
